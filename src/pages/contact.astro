---
import TeamLayout from '../layouts/TeamLayout.astro';
import TeamNavbar from '../components/TeamNavbar.astro';
import TeamFooter from '../components/TeamFooter.astro';
import { loadConfig } from '../utils/config';

const config = loadConfig();
const { mode, site, company, theme } = config;
---

<TeamLayout title={company?.name ? `联系我们 - ${company.name}` : '联系我们'} description={company?.description} theme={theme}>
  <TeamNavbar siteName={company?.name || 'Team'} />
  
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="py-20 px-4 relative overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--hero-gradient));"></div>
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          联系我们
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          有任何问题？我们随时为您服务
        </p>
      </div>
    </section>

    <!-- Contact Info & Form -->
    <section class="py-16 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div>
            <h2 class="text-2xl font-bold mb-6" style="color: var(--primary);">联系方式</h2>
            <div class="space-y-4">
              {company?.address && (
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: var(--gradient);">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900 dark:text-white">地址</p>
                    <p class="text-gray-600 dark:text-gray-300">{company.address}</p>
                  </div>
                </div>
              )}
              {company?.phone && (
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: var(--gradient);">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900 dark:text-white">电话</p>
                    <p class="text-gray-600 dark:text-gray-300">{company.phone}</p>
                  </div>
                </div>
              )}
              {company?.email && (
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: var(--gradient);">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900 dark:text-white">邮箱</p>
                    <p class="text-gray-600 dark:text-gray-300">{company.email}</p>
                  </div>
                </div>
              )}
            </div>

            <!-- Social Links -->
            {config.socials && config.socials.length > 0 && (
              <div class="mt-8">
                <h3 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">关注我们</h3>
                <div class="flex gap-4">
                  {config.socials.map((social) => (
                    <a 
                      href={social.url} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="w-10 h-10 rounded-lg flex items-center justify-center bg-gray-100 dark:bg-gray-800 hover:opacity-80 transition-opacity"
                      style="background: var(--gradient);"
                    >
                      <span class="text-white text-sm">{social.platform}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Contact Form -->
          <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-md">
            <h2 class="text-2xl font-bold mb-6" style="color: var(--primary);">发送消息</h2>
            <form class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">姓名</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:outline-none"
                  style="--tw-ring-color: var(--primary);"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">邮箱</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:outline-none"
                  style="--tw-ring-color: var(--primary);"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">消息</label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="4" 
                  required
                  class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:outline-none resize-none"
                  style="--tw-ring-color: var(--primary);"
                ></textarea>
              </div>
              <button 
                type="submit"
                class="w-full py-3 px-6 rounded-lg text-white font-semibold transition-opacity hover:opacity-90"
                style="background: var(--primary);"
              >
                发送消息
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <TeamFooter company={company} socials={config.socials} />
</TeamLayout>