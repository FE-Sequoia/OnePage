---
import TeamLayout from '../layouts/TeamLayout.astro';
import TeamNavbar from '../components/TeamNavbar.astro';
import TeamFooter from '../components/TeamFooter.astro';
import { loadConfig } from '../utils/config';

const config = loadConfig();
const { mode, company, services, theme } = config;
---

<TeamLayout title={company?.name ? `服务范围 - ${company.name}` : '服务范围'} description="我们的服务范围" theme={theme}>
  <TeamNavbar siteName={company?.name || 'Team'} />
  
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="py-20 px-4 relative overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--hero-gradient));"></div>
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          服务范围
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          为您提供全方位的互联网解决方案
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-16 px-4">
      <div class="max-w-6xl mx-auto">
        {services && services.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {services.map((service) => (
              <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-lg">
                <div class="flex items-start gap-4">
                  <div 
                    class="w-14 h-14 rounded-xl flex items-center justify-center flex-shrink-0"
                    style="background: var(--gradient);"
                  >
                    <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      {service.icon === 'code' && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                      )}
                      {service.icon === 'mobile' && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                      )}
                      {service.icon === 'design' && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                      )}
                      {service.icon === 'cloud' && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                      )}
                    </svg>
                  </div>
                  
                  <div class="flex-1">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
                      {service.name}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300 mb-4">
                      {service.description}
                    </p>
                    
                    {service.features && service.features.length > 0 && (
                      <ul class="space-y-2">
                        {service.features.map((feature) => (
                          <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                            <svg class="w-4 h-4" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            {feature}
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <p class="text-gray-500">暂无服务信息</p>
          </div>
        )}
      </div>
    </section>
  </main>

  <TeamFooter company={company} socials={config.socials} />
</TeamLayout>