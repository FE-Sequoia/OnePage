---
import TeamLayout from '../layouts/TeamLayout.astro';
import TeamNavbar from '../components/TeamNavbar.astro';
import TeamFooter from '../components/TeamFooter.astro';
import { loadConfig } from '../utils/config';

const config = loadConfig();
const { mode, company, services, theme } = config;
---

<TeamLayout title={company?.name ? `服务范围 - ${company.name}` : '服务范围'} description="我们的服务范围" theme={theme}>
  <TeamNavbar siteName={company?.name || 'Team'} />
  
  <main class="relative overflow-hidden">
    <!-- Animated Background -->
    <div class="fixed inset-0 -z-10">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--hero-gradient));"></div>
      <div class="blob w-[400px] h-[400px] top-60 -left-24" style="background: var(--primary-light); opacity: 0.3;"></div>
      <div class="blob w-[350px] h-[350px] bottom-20 -right-32" style="background: var(--accent-light); opacity: 0.25;"></div>
    </div>

    <!-- Hero Section -->
    <section class="py-32 px-4 relative">
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <span class="inline-block px-4 py-1.5 rounded-full text-sm font-medium mb-6 glass fade-in" style="color: var(--primary);">Services</span>
        <h1 class="text-5xl md:text-6xl font-bold mb-6 fade-in-up">
          服务<span class="gradient-text">范围</span>
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto fade-in-up animate-delay-200">
          为您提供全方位的互联网解决方案
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-24 px-4">
      <div class="max-w-6xl mx-auto">
        {services && services.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map((service, index) => (
              <div class="group glass rounded-2xl p-8 hover-lift hover-glow transition-all duration-500 animate-on-scroll" style={`animation-delay: ${index * 100}ms;`}>
                <div class="flex items-start gap-4">
                  <div 
                    class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0 hover-scale transition-transform duration-300"
                    style="background: var(--gradient);"
                  >
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      {service.icon === 'code' && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                      )}
                      {service.icon === 'mobile' && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                      )}
                      {service.icon === 'design' && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                      )}
                      {service.icon === 'cloud' && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                      )}
                      {!['code', 'mobile', 'design', 'cloud'].includes(service.icon) && (
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                      )}
                    </svg>
                  </div>
                  
                  <div class="flex-1">
                    <h3 class="text-xl font-bold mb-2 group-hover:gradient-text transition-all duration-300">
                      {service.name}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300 mb-4">
                      {service.description}
                    </p>
                    
                    {service.features && service.features.length > 0 && (
                      <ul class="space-y-2">
                        {service.features.map((feature) => (
                          <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                            <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--primary);"></span>
                            {feature}
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-16 glass rounded-2xl">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-50" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.372 3.372 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            <p class="text-gray-500 text-lg">暂无服务信息</p>
            <p class="text-gray-400 text-sm mt-2">添加服务到 config/services.yaml</p>
          </div>
        )}
      </div>
    </section>
  </main>

  <TeamFooter company={company} socials={config.socials} />
</TeamLayout>