---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  favicon?: string;
  theme?: {
    name: string;
    colors: {
      primary: string;
      primaryLight: string;
      primaryDark: string;
      accent: string;
      accentLight: string;
      gradient: string;
      heroGradient: string;
      heroGradientDark: string;
    };
  };
}

const { title, description, favicon, theme } = Astro.props;
const colors = theme?.colors;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={favicon || '/favicon.ico'} />
    <meta name="description" content={description || title} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style define:vars={{ 
      primary: colors?.primary || '#3b82f6',
      primaryLight: colors?.primaryLight || '#60a5fa',
      primaryDark: colors?.primaryDark || '#2563eb',
      accent: colors?.accent || '#06b6d4',
      accentLight: colors?.accentLight || '#22d3ee',
      gradient: colors?.gradient || 'linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%)',
      heroGradient: colors?.heroGradient || 'linear-gradient(135deg, #eff6ff 0%, #e0f2fe 50%, #f0f9ff 100%)',
      heroGradientDark: colors?.heroGradientDark || 'linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #172554 100%)'
    }}>
      :root {
        --primary: var(--primary);
        --primary-light: var(--primaryLight);
        --primary-dark: var(--primaryDark);
        --accent: var(--accent);
        --accent-light: var(--accentLight);
        --gradient: var(--gradient);
        --hero-gradient: var(--heroGradient);
        --hero-gradient-dark: var(--heroGradientDark);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Outfit', sans-serif;
        overflow-x: hidden;
      }

      .font-display {
        font-family: 'Space Grotesk', sans-serif;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
      }

      @keyframes pulse-ring {
        0% { transform: scale(0.8); opacity: 1; }
        100% { transform: scale(2); opacity: 0; }
      }

      @keyframes gradient-flow {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      @keyframes star-glow {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.2); }
      }

      @keyframes orbit {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      @keyframes tilt {
        0%, 100% { transform: rotateX(0deg) rotateY(0deg); }
        25% { transform: rotateX(5deg) rotateY(-5deg); }
        50% { transform: rotateX(0deg) rotateY(-10deg); }
        75% { transform: rotateX(-5deg) rotateY(5deg); }
      }

      .perspective-1000 {
        perspective: 1000px;
      }

      .preserve-3d {
        transform-style: preserve-3d;
      }

      .backface-hidden {
        backface-visibility: hidden;
      }

      .animate-float {
        animation: float 6s ease-in-out infinite;
      }

      .animate-float-delayed {
        animation: float 6s ease-in-out infinite;
        animation-delay: 3s;
      }

      .animate-pulse-ring {
        animation: pulse-ring 2s ease-out infinite;
      }

      .animate-gradient-flow {
        background-size: 200% 200%;
        animation: gradient-flow 8s ease infinite;
      }

      .animate-blink {
        animation: blink 1s step-end infinite;
      }

      .animate-star-glow {
        animation: star-glow 3s ease-in-out infinite;
      }

      .animate-tilt {
        animation: tilt 8s ease-in-out infinite;
      }

      .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .dark .glass-card {
        background: rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .gradient-border {
        position: relative;
        background: linear-gradient(var(--hero-gradient), var(--hero-gradient));
        border-radius: 1rem;
      }

      .gradient-border::before {
        content: '';
        position: absolute;
        inset: -2px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        border-radius: calc(1rem + 2px);
        z-index: -1;
        opacity: 0.5;
      }

      .gradient-text {
        background: linear-gradient(135deg, var(--primary), var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hover-lift {
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }

      .hover-lift:hover {
        transform: translateY(-10px) rotateX(5deg);
      }

      .hover-glow {
        transition: all 0.3s ease;
      }

      .hover-glow:hover {
        box-shadow: 0 0 40px rgba(59, 130, 246, 0.4);
      }

      .orbit-container {
        position: relative;
        animation: orbit 20s linear infinite;
      }

      .glow-spot {
        filter: blur(60px);
      }

      .noise-overlay::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        opacity: 0.03;
        pointer-events: none;
        z-index: 9999;
      }

      .scroll-indicator {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
      }

      .mouse-scroll {
        width: 26px;
        height: 40px;
        border: 2px solid currentColor;
        border-radius: 20px;
        position: relative;
      }

      .mouse-scroll::before {
        content: '';
        position: absolute;
        top: 6px;
        left: 50%;
        transform: translateX(-50%);
        width: 4px;
        height: 8px;
        background: currentColor;
        border-radius: 2px;
        animation: scroll 2s ease-in-out infinite;
      }

      @keyframes scroll {
        0% { opacity: 1; transform: translateX(-50%) translateY(0); }
        100% { opacity: 0; transform: translateX(-50%) translateY(12px); }
      }

      .circle-progress {
        transform: rotate(-90deg);
      }

      .circle-progress circle {
        transition: stroke-dashoffset 1s ease;
      }

      .card-3d {
        transform-style: preserve-3d;
        transition: transform 0.5s ease;
      }

      .card-3d:hover {
        transform: rotateX(5deg) rotateY(-5deg) translateZ(20px);
      }

      .text-reveal {
        clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
        animation: text-reveal 1s ease forwards;
      }

      @keyframes text-reveal {
        from { clip-path: polygon(0 100%, 100% 100%, 100% 100%, 0% 100%); }
        to { clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%); }
      }
    </style>
  </head>
  <body class="bg-white dark:bg-dark text-gray-900 dark:text-white">
    <div class="noise-overlay"></div>
    <slot />
  </body>
</html>

<script is:inline>
  const theme = localStorage.getItem('theme');
  if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    document.documentElement.classList.add('dark');
  }
</script>