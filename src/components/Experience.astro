---
interface Props {
  experience?: { company: string; position: string; period: string; description?: string }[];
}

const { experience } = Astro.props;
---

<section id="experience" class="py-24 px-4" style="background: linear-gradient(180deg, #fff 0%, #f0f9ff 100%);">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">工作经历</h2>
      <div class="w-16 h-1 mx-auto rounded-full" style="background: linear-gradient(to right, var(--primary), var(--accent));"></div>
    </div>

    {experience && experience.length > 0 && (
      <div class="relative">
        <div class="absolute left-4 top-0 bottom-0 w-0.5" style="background: linear-gradient(to bottom, var(--primary), var(--accent));"></div>
        
        {experience.map((exp, idx) => (
          <div class="relative pl-10 mb-6">
            <div class="absolute left-2 top-4 w-5 h-5 rounded-full bg-white border-3" style="border-color: var(--primary);"></div>
            <div class="bg-white rounded-xl p-5 shadow-md hover:shadow-lg transition-shadow duration-300" style={`border-left: 4px solid ${idx % 2 === 0 ? 'var(--primary)' : 'var(--accent)'};`}>
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
                <h3 class="text-lg font-bold text-gray-900">{exp.company}</h3>
                <span class="px-3 py-1 rounded-full text-xs text-white font-medium" style="background: var(--primary);">{exp.period}</span>
              </div>
              <p class="font-semibold" style="color: var(--primary);">{exp.position}</p>
              {exp.description && <p class="text-sm text-gray-600 mt-2 leading-relaxed">{exp.description}</p>}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>