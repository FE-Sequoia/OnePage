---
interface Props {
  experience?: { company: string; position: string; period: string; description?: string }[];
}

const { experience } = Astro.props;
---

<section id="experience" class="py-16 px-4 relative overflow-hidden">
  <div class="absolute inset-0 bg-white dark:bg-dark -z-10"></div>
  <div class="absolute top-10 left-0 w-72 h-72 rounded-full blur-3xl" style="background: var(--accent, #06b6d4); opacity: 0.1;"></div>
  <div class="absolute bottom-10 right-0 w-72 h-72 rounded-full blur-3xl" style="background: var(--primary, #3b82f6); opacity: 0.1;"></div>

  <div class="max-w-4xl mx-auto relative">
    <div class="text-center mb-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        工作经历
      </h2>
      <div class="w-20 h-1.5 mx-auto rounded-full" style="background: linear-gradient(to right, var(--primary, #3b82f6), var(--accent, #06b6d4));"></div>
    </div>

    {experience && experience.length > 0 && (
      <div class="relative">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 transform md:-translate-x-1/2" style="background: linear-gradient(to bottom, var(--primary, #3b82f6), var(--accent, #06b6d4), var(--primary, #3b82f6)); opacity: 0.3;"></div>

        <div class="space-y-6">
          {experience.map((exp, index) => (
            <div class={`relative flex items-center ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full transform -translate-x-1/2 ring-4 ring-white dark:ring-gray-900" style="background: linear-gradient(135deg, var(--primary, #3b82f6), var(--accent, #06b6d4));"></div>

              <div class={`ml-12 md:ml-0 md:w-5/12 ${index % 2 === 0 ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8'} text-left`}>
                <div class="bg-white/80 dark:bg-gray-800/50 rounded-xl p-4 shadow-md border border-gray-100/50 dark:border-gray-700/50 backdrop-blur-sm">
                  <h3 class="text-base font-bold text-gray-900 dark:text-white">
                    {exp.company}
                  </h3>
                  <p class="text-sm font-medium" style="color: var(--primary, #3b82f6);">
                    {exp.position}
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    {exp.period}
                  </p>
                </div>
              </div>

              <div class="hidden md:block md:w-5/12"></div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
