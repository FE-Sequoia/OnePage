---
interface Props {
  experience?: { company: string; position: string; period: string; description?: string }[];
}

const { experience } = Astro.props;
---

<section id="experience" class="py-24 px-4 bg-gray-50 dark:bg-gray-900/50">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">
        工作经历
      </h2>
      <div class="w-16 h-1 mx-auto rounded-full" style="background: linear-gradient(to right, var(--primary), var(--accent));"></div>
    </div>

    {experience && experience.length > 0 && (
      <div class="relative pl-8 border-l-2" style="border-color: var(--primary);">
        {experience.map((exp) => (
          <div class="relative mb-8">
            <div class="absolute -left-[41px] w-5 h-5 rounded-full bg-white border-4" style="border-color: var(--primary);"></div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-5 shadow-sm border border-gray-100 dark:border-gray-700">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{exp.company}</h3>
                <span class="text-sm text-gray-500">{exp.period}</span>
              </div>
              <p class="font-medium" style="color: var(--primary);">{exp.position}</p>
              {exp.description && <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">{exp.description}</p>}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>