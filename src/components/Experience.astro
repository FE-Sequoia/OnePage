---
interface Props {
  experience?: { company: string; position: string; period: string; description?: string }[];
}

const { experience } = Astro.props;
---

<section id="experience" class="py-24 px-4 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-20 -left-32 w-72 h-72 rounded-full blur-3xl opacity-30" style="background: var(--accent);"></div>
    <div class="absolute bottom-20 -right-32 w-72 h-72 rounded-full blur-3xl opacity-25" style="background: var(--primary);"></div>
  </div>

  <div class="max-w-4xl mx-auto relative">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 rounded-full text-sm font-medium mb-4 glass-card" style="color: var(--primary);">Experience</span>
      <h2 class="text-4xl md:text-5xl font-bold mb-4 font-display">
        工作<span class="gradient-text">经历</span>
      </h2>
      <p class="text-gray-600 dark:text-gray-400 max-w-xl mx-auto">每一段经历都是成长的痕迹</p>
    </div>

    {experience && experience.length > 0 && (
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-0.5 transform md:-translate-x-1/2" style="background: linear-gradient(to bottom, var(--primary), var(--accent)); opacity: 0.2;"></div>

        <div class="space-y-8">
          {experience.map((exp, index) => (
            <div class={`relative flex items-start ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <!-- Timeline dot -->
              <div class="absolute left-8 md:left-1/2 w-5 h-5 rounded-full transform -translate-x-1/2 z-10">
                <div class="absolute inset-0 rounded-full animate-pulse-ring" style="background: linear-gradient(135deg, var(--primary), var(--accent));"></div>
                <div class="relative w-full h-full rounded-full bg-white dark:bg-gray-800 ring-4 ring-white dark:ring-gray-900"></div>
              </div>

              <!-- Content card -->
              <div class={`ml-16 md:ml-0 md:w-5/12 ${index % 2 === 0 ? 'md:mr-auto md:pr-12' : 'md:ml-auto md:pl-12'} animate-float`} style={`animation-delay: ${index * -2}s;`}>
                <div class="glass-card rounded-2xl p-6 hover-lift hover-glow transition-all duration-500">
                  <div class="flex items-start justify-between mb-3">
                    <div>
                      <h3 class="text-lg font-bold">{exp.company}</h3>
                      <p class="text-sm font-medium" style="color: var(--primary);">{exp.position}</p>
                    </div>
                    <span class="px-3 py-1 rounded-full text-xs font-medium" style="background: var(--gradient); color: white;">
                      {exp.period}
                    </span>
                  </div>
                  {exp.description && (
                    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                      {exp.description}
                    </p>
                  )}
                </div>
              </div>

              <!-- Empty space for alternating layout -->
              <div class="hidden md:block md:w-5/12"></div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>