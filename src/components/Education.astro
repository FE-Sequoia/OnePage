---
interface Props {
  education?: { school: string; degree: string; period: string; description?: string }[];
}

const { education } = Astro.props;
---

<section id="education" class="py-16 px-4 relative overflow-hidden">
  <div class="absolute inset-0 bg-gray-50/50 dark:bg-darker/50 -z-10"></div>
  <div class="absolute top-0 left-1/4 w-64 h-64 rounded-full blur-3xl" style="background: var(--primary, #8b5cf6); opacity: 0.15;"></div>
  <div class="absolute bottom-0 right-1/4 w-64 h-64 rounded-full blur-3xl" style="background: var(--accent, #3b82f6); opacity: 0.15;"></div>

  <div class="max-w-4xl mx-auto relative">
    <div class="text-center mb-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        教育经历
      </h2>
      <div class="w-20 h-1.5 mx-auto rounded-full" style="background: linear-gradient(to right, var(--primary, #3b82f6), var(--accent, #06b6d4));"></div>
    </div>

    {education && education.length > 0 && (
      <div class="space-y-3">
        {education.map((edu) => (
          <div class="bg-white/80 dark:bg-gray-800/50 rounded-xl p-4 shadow-md border border-gray-100/50 dark:border-gray-700/50 backdrop-blur-sm">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
              <h3 class="text-lg font-bold text-gray-900 dark:text-white">
                {edu.school}
              </h3>
              <span class="text-sm text-gray-500 dark:text-gray-400">
                {edu.period}
              </span>
            </div>
            <p class="font-medium text-sm mt-1" style="color: var(--primary, #3b82f6);">
              {edu.degree}
            </p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
