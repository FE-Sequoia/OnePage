---
interface Props {
  education?: { school: string; degree: string; period: string; description?: string }[];
}

const { education } = Astro.props;
---

<section id="education" class="py-24 px-4 bg-white dark:bg-dark">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">
        教育背景
      </h2>
      <div class="w-16 h-1 mx-auto rounded-full" style="background: linear-gradient(to right, var(--primary), var(--accent));"></div>
    </div>

    {education && education.length > 0 && (
      <div class="space-y-4">
        {education.map((edu) => (
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-5 shadow-sm border border-gray-100 dark:border-gray-700">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{edu.school}</h3>
                <p class="font-medium" style="color: var(--primary);">{edu.degree}</p>
              </div>
              <span class="text-sm text-gray-500">{edu.period}</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>