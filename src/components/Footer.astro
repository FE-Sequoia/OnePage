---
interface Props {
  name?: string;
}

const { name } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="py-10 px-4" style="background: linear-gradient(180deg, #fff 0%, #f0f9ff 100%);">
  <div class="max-w-5xl mx-auto text-center">
    <div class="flex justify-center gap-2 mb-4">
      <div class="w-3 h-3 rounded-full" style="background: var(--primary);"></div>
      <div class="w-3 h-3 rounded-full" style="background: var(--accent);"></div>
      <div class="w-3 h-3 rounded-full" style="background: var(--primary-light);"></div>
    </div>
    <p class="text-gray-600 font-medium mb-1">
      &copy; {year} {name || 'OnePage'}. All Rights Reserved.
    </p>
    <p class="text-sm text-gray-400">
      Powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-primary font-medium hover:underline">Astro</a> 
      <span class="text-gray-300">+</span> 
      <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="text-accent font-medium hover:underline">Tailwind CSS</a>
    </p>
  </div>
</footer>