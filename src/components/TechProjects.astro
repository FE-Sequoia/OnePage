---
// 案例展示组件 - 三列布局
interface Props {
  projects?: { 
    name: string; 
    description: string; 
    tech: string[]; 
    image?: string; 
    link?: string; 
    demo?: string; 
    results?: string[];
  }[];
}

const { projects } = Astro.props;

// 默认案例数据
const defaultProjects = [
  {
    name: "企业级SaaS平台",
    description: "为B2B企业打造的一站式管理平台，服务超过10000名日活用户，采用微服务架构实现高可用。",
    tech: ["Next.js", "Node.js", "PostgreSQL", "Redis", "AWS"],
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&h=400&fit=crop",
    link: "#",
    demo: "#",
    results: ["成本降低40%", "99.9%可用性", "10000+日活"]
  },
  {
    name: "智能数据分析平台",
    description: "基于机器学习的商业智能系统，日处理百万级数据，为企业提供精准的数据洞察。",
    tech: ["React", "Python", "TensorFlow", "GraphQL", "Docker"],
    image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=400&fit=crop",
    link: "#",
    demo: "#",
    results: ["日处理100万+数据", "预测准确率85%", "洞察速度提升3倍"]
  },
  {
    name: "电商平台系统",
    description: "支持高并发的电商交易系统，月交易额超过200万美元，集成支付、库存、物流全流程。",
    tech: ["Vue.js", "Node.js", "MongoDB", "Stripe", "Kubernetes"],
    image: "https://images.unsplash.com/photo-1563013544-824ae1b704d3?w=600&h=400&fit=crop",
    link: "#",
    demo: "#",
    results: ["月GMV 200万+", "50000+商品", "响应<100ms"]
  },
  {
    name: "实时协作系统",
    description: "支持千人在线的协同办公平台，集成文档编辑、视频会议、即时通讯等核心功能。",
    tech: ["TypeScript", "WebRTC", "Socket.io", "Redis", "GCP"],
    image: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&h=400&fit=crop",
    link: "#",
    demo: "#",
    results: ["支持1000+并发", "延迟<50ms", "99.99%可靠性"]
  },
  {
    name: "金融风控系统",
    description: "为金融机构打造的风控决策引擎，实时风险评估，日均处理交易超过500万笔。",
    tech: ["React", "Go", "Kafka", "PostgreSQL", "阿里云"],
    image: "https://images.unsplash.com/photo-1559526324-4b87b5e36e44?w=600&h=400&fit=crop",
    link: "#",
    demo: "#",
    results: ["日处理500万+交易", "风控准确率99.5%", "响应时间<20ms"]
  },
  {
    name: "物联网管理平台",
    description: "连接百万级IoT设备的设备管理平台，支持设备监控、远程控制、数据分析。",
    tech: ["Vue.js", "Node.js", "MQTT", "InfluxDB", "AWS IoT"],
    image: "https://images.unsplash.com/photo-1518770660439-4636190af475?w=600&h=400&fit=crop",
    link: "#",
    demo: "#",
    results: ["连接100万+设备", "实时数据流", "设备在线率99.8%"]
  }
];

const displayProjects = projects && projects.length > 0 ? projects : defaultProjects;
---

<section id="projects" class="py-24 px-4 relative overflow-hidden">
  <!-- 背景装饰 -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-0 w-[500px] h-[500px] bg-cyan-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/3 left-0 w-[500px] h-[500px] bg-blue-500/5 rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- 标题区 -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-6">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        <span class="text-sm font-medium text-cyan-300">项目案例</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-cyan-400">
          精选成功案例
        </span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-lg">
        多年积累的全栈开发经验，为企业交付高质量的技术解决方案
      </p>
    </div>

    <!-- 三列网格布局 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {displayProjects.map((project, idx) => (
        <article class="group glass-card rounded-2xl overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl hover:shadow-cyan-500/10">
          {/* 图片区 */}
          <div class="relative h-48 overflow-hidden">
            <img
              src={project.image}
              alt={project.name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/50 to-transparent"></div>
            
            {/* 成果标签 */}
            {project.results && (
              <div class="absolute top-3 left-3 flex flex-wrap gap-1">
                {project.results.slice(0, 2).map((result) => (
                  <span class="px-2 py-1 rounded-full text-xs font-medium bg-green-500/20 text-green-300 border border-green-500/30">
                    {result}
                  </span>
                ))}
              </div>
            )}
          </div>
          
          {/* 内容区 */}
          <div class="p-5">
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-300 transition-colors">
              {project.name}
            </h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-4 line-clamp-2">
              {project.description}
            </p>
            
            {/* 技术栈 */}
            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.tech.slice(0, 4).map((t) => (
                <span class="px-2 py-0.5 rounded text-xs font-medium bg-slate-700/50 text-slate-300 border border-slate-600/30">
                  {t}
                </span>
              ))}
            </div>
            
            {/* 操作按钮 */}
            <div class="flex gap-2 pt-3 border-t border-slate-700/50">
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg glass text-cyan-300 hover:bg-cyan-500/10 transition-all duration-300 text-sm font-medium"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                  源码
                </a>
              )}
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg bg-gradient-to-r from-blue-600 to-cyan-600 text-white hover:brightness-110 transition-all duration-300 text-sm font-medium"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                  演示
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    {/* CTA */}
    <div class="mt-12 text-center">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold glass text-cyan-300 border border-cyan-500/30 hover:border-cyan-500/60 hover:bg-cyan-500/10 transition-all duration-300"
      >
        <span>讨论您的项目</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .glass-card {
    background: rgba(30, 41, 59, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .glass {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
