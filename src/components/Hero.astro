---
interface Props {
  name: string;
  title: string;
  avatar?: string;
  bio?: string;
  email?: string;
  socials?: { platform: string; url: string; icon: string }[];
}

const { name, title, avatar, bio, email, socials } = Astro.props;
---

<section id="about" class="min-h-screen flex flex-col justify-center items-center py-20 px-4 relative overflow-hidden" style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #dbeafe 100%);">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-10 -right-20 w-72 h-72 rounded-full blur-3xl opacity-40" style="background: var(--accent);"></div>
    <div class="absolute bottom-10 -left-20 w-64 h-64 rounded-full blur-3xl opacity-30" style="background: var(--primary);"></div>
  </div>
  
  <div class="max-w-4xl w-full text-center relative z-10">
    {avatar && (
      <div class="mb-8 relative inline-block">
        <div class="absolute inset-0 rounded-full ring-4 ring-white" style="box-shadow: 0 0 20px var(--primary-light);"></div>
        <img
          src={avatar}
          alt={name}
          class="relative w-36 h-36 mx-auto rounded-full object-cover shadow-xl ring-4 ring-white"
        />
      </div>
    )}

    <h1 class="text-5xl md:text-6xl font-bold mb-3 text-gray-900">
      {name}
    </h1>

    <div class="text-xl md:text-2xl text-gray-600 mb-4 font-medium">
      <span id="typewriter"></span>
    </div>

    {bio && (
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
        {bio}
      </p>
    )}

    <div class="flex flex-wrap justify-center gap-3 mb-8">
      {socials?.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 bg-white text-gray-700 rounded-full shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 font-medium text-sm border border-gray-200 hover:border-primary"
        >
          {social.platform}
        </a>
      ))}
      {email && (
        <a
          href={`mailto:${email}`}
          class="px-6 py-2.5 text-white rounded-full shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 font-medium text-sm"
          style="background: linear-gradient(135deg, var(--primary), var(--accent));"
        >
          联系我
        </a>
      )}
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-gray-400">
    <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<script is:inline>
  const titleText = title || 'Developer';
  const typewriter = document.getElementById('typewriter');
  let charIndex = 0;
  
  function type() {
    if (charIndex < titleText.length && typewriter) {
      typewriter.textContent += titleText.charAt(charIndex);
      charIndex++;
      setTimeout(type, 120);
    }
  }
  type();
</script>