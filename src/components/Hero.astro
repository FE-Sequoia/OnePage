---
interface Props {
  name: string;
  title: string;
  avatar?: string;
  bio?: string;
  email?: string;
  socials?: { platform: string; url: string; icon: string }[];
}

const { name, title, avatar, bio, email, socials } = Astro.props;
---

<section id="about" class="min-h-screen flex flex-col justify-center items-center py-20 px-4 relative overflow-hidden" style="background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 left-0 w-full h-64" style="background: linear-gradient(180deg, rgba(59, 130, 246, 0.15) 0%, transparent 100%);"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 rounded-full blur-3xl opacity-30" style="background: var(--accent);"></div>
  </div>
  
  <canvas id="stars" class="absolute inset-0 -z-10"></canvas>
  
  <div class="max-w-4xl w-full text-center relative z-10">
    {avatar && (
      <div class="mb-8 relative inline-block">
        <div class="absolute inset-0 rounded-full animate-pulse-ring" style="background: linear-gradient(var(--primary), var(--accent));"></div>
        <img
          src={avatar}
          alt={name}
          class="relative w-32 h-32 mx-auto rounded-full object-cover shadow-xl ring-4 ring-white"
        />
      </div>
    )}

    <h1 class="text-5xl md:text-6xl font-bold font-display mb-3 text-gray-900">
      <span class="gradient-text">{name}</span>
    </h1>

    <div class="text-xl md:text-2xl mb-6 h-8">
      <span id="typewriter" class="text-gray-500"></span>
      <span class="inline-block w-0.5 h-6 ml-1 align-middle animate-blink" style="background: var(--primary);"></span>
    </div>

    {bio && (
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
        {bio}
      </p>
    )}

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      {socials?.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 bg-white text-gray-700 rounded-lg shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 font-medium text-sm border border-gray-200"
        >
          {social.platform}
        </a>
      ))}
      {email && (
        <a
          href={`mailto:${email}`}
          class="px-6 py-2.5 text-white rounded-lg shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 font-medium text-sm"
          style="background: linear-gradient(135deg, var(--primary), var(--accent));"
        >
          联系我
        </a>
      )}
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-gray-400">
    <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<script is:inline>
  const titleText = `/${title || 'Developer'}`;
  const typewriter = document.getElementById('typewriter');
  let charIndex = 0;
  
  function type() {
    if (charIndex < titleText.length && typewriter) {
      typewriter.textContent += titleText.charAt(charIndex);
      charIndex++;
      setTimeout(type, 100 + Math.random() * 100);
    }
  }
  
  setTimeout(type, 1000);

  const canvas = document.getElementById('stars');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    const stars = [];
    for (let i = 0; i < 100; i++) {
      stars.push({
        x: Math.random() * width,
        y: Math.random() * height,
        radius: Math.random() * 1 + 0.5,
        alpha: Math.random(),
        speed: Math.random() * 0.02 + 0.005
      });
    }

    function drawStars() {
      ctx.clearRect(0, 0, width, height);
      stars.forEach(star => {
        star.alpha += star.speed;
        if (star.alpha > 1 || star.alpha < 0.2) star.speed = -star.speed;
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(59, 130, 246, ${star.alpha * 0.6})`;
        ctx.fill();
      });
      requestAnimationFrame(drawStars);
    }
    drawStars();

    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    });
  }
</script>