---
interface Props {
  company?: {
    name: string;
    email: string;
    phone: string;
    address: string;
  };
  socials?: { platform: string; url: string }[];
}

const { company, socials } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="relative py-16 px-4 overflow-hidden" style="background: linear-gradient(180deg, var(--hero-gradient) 0%, var(--hero-gradient-dark) 100%);">
  <div class="absolute inset-0 grid-pattern opacity-50"></div>
  <div class="blob w-96 h-96 top-0 -left-32" style="background: var(--primary-light);"></div>
  <div class="blob w-80 h-80 bottom-0 -right-32" style="background: var(--accent-light);"></div>
  
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <div class="animate-on-scroll fade-in-left">
        <h3 class="text-lg font-bold mb-4 gradient-text">关于我们</h3>
        <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
          专业的互联网解决方案提供商，致力于为客户创造价值。
        </p>
      </div>
      
      <div class="animate-on-scroll fade-in-left animate-delay-100">
        <h3 class="text-lg font-bold mb-4 gradient-text">快速链接</h3>
        <ul class="space-y-3">
          <li><a href="/OnePage/" class="text-gray-600 dark:text-gray-300 hover:text-primary hover-lift inline-block transition-all">首页</a></li>
          <li><a href="/OnePage/about" class="text-gray-600 dark:text-gray-300 hover:text-primary hover-lift inline-block transition-all">关于我们</a></li>
          <li><a href="/OnePage/portfolio" class="text-gray-600 dark:text-gray-300 hover:text-primary hover-lift inline-block transition-all">案例展示</a></li>
          <li><a href="/OnePage/services" class="text-gray-600 dark:text-gray-300 hover:text-primary hover-lift inline-block transition-all">服务范围</a></li>
          <li><a href="/OnePage/news" class="text-gray-600 dark:text-gray-300 hover:text-primary hover-lift inline-block transition-all">新闻动态</a></li>
          <li><a href="/OnePage/contact" class="text-gray-600 dark:text-gray-300 hover:text-primary hover-lift inline-block transition-all">联系我们</a></li>
        </ul>
      </div>
      
      <div class="animate-on-scroll fade-in-left animate-delay-200">
        <h3 class="text-lg font-bold mb-4 gradient-text">联系方式</h3>
        <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-300">
          {company?.email && (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {company.email}
            </li>
          )}
          {company?.phone && (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {company.phone}
            </li>
          )}
          {company?.address && (
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="leading-tight">{company.address}</span>
            </li>
          )}
        </ul>
      </div>
      
      <div class="animate-on-scroll fade-in-left animate-delay-300">
        <h3 class="text-lg font-bold mb-4 gradient-text">关注我们</h3>
        <div class="flex flex-wrap gap-3">
          {socials?.map((social, index) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-lg flex items-center justify-center hover-scale hover-glow transition-all duration-300"
              style="background: var(--gradient);"
              title={social.platform}
            >
              <span class="text-white text-xs font-medium">{social.platform.slice(0, 2)}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <div class="text-center pt-8 border-t border-gray-200/30 dark:border-gray-700/30">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        &copy; {year} <span class="gradient-text font-medium">{company?.name || 'OnePage'}</span>. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>