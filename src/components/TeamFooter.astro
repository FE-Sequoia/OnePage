---
interface Props {
  company?: {
    name: string;
    email: string;
    phone: string;
    address: string;
  };
  socials?: { platform: string; url: string }[];
}

const { company, socials } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="py-12 px-4 bg-gray-50 dark:bg-darker border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div>
        <h3 class="text-lg font-bold mb-4" style="color: var(--primary);">关于我们</h3>
        <p class="text-gray-600 dark:text-gray-400 text-sm">
          专业的互联网解决方案提供商，致力于为客户创造价值。
        </p>
      </div>
      
      <div>
        <h3 class="text-lg font-bold mb-4" style="color: var(--primary);">快速链接</h3>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
          <li><a href="/OnePage/" class="hover:text-primary">首页</a></li>
          <li><a href="/OnePage/about" class="hover:text-primary">关于我们</a></li>
          <li><a href="/OnePage/portfolio" class="hover:text-primary">案例展示</a></li>
          <li><a href="/OnePage/contact" class="hover:text-primary">联系我们</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="text-lg font-bold mb-4" style="color: var(--primary);">联系方式</h3>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
          {company?.email && <li>邮箱: {company.email}</li>}
          {company?.phone && <li>电话: {company.phone}</li>}
          {company?.address && <li>地址: {company.address}</li>}
        </ul>
      </div>
      
      <div>
        <h3 class="text-lg font-bold mb-4" style="color: var(--primary);">关注我们</h3>
        <div class="flex gap-4">
          {socials?.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-600 dark:text-gray-400 hover:text-primary"
            >
              {social.platform}
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <div class="text-center pt-8 border-t border-gray-200 dark:border-gray-800">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        &copy; {year} {company?.name || 'OnePage'}. All Rights Reserved.
      </p>
    </div>
  </div>
</footer>