---
interface Props {
  name: string;
}

const { name } = Astro.props;

const navItems = [
  { label: '首页', href: '#about' },
  { label: '技能', href: '#skills' },
  { label: '案例', href: '#projects' },
  { label: '经历', href: '#experience' },
  { label: '联系', href: '#contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-dark/80 backdrop-blur-lg border-b border-gray-100 dark:border-gray-800">
  <nav class="max-w-6xl mx-auto px-4 py-3 flex justify-between items-center">
    <a href="#about" class="text-xl font-bold bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent hover:opacity-80 transition-opacity">
      {name}
    </a>

    <ul class="hidden md:flex items-center gap-1">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="px-4 py-2 text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 rounded-lg transition-all duration-200 text-sm font-medium"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-600 dark:text-gray-300 hover:text-primary transition-colors"
      aria-label="菜单"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden bg-white dark:bg-dark border-t border-gray-100 dark:border-gray-800">
    <ul class="px-4 py-2 space-y-1">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block py-3 px-4 text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 rounded-lg transition-colors"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
