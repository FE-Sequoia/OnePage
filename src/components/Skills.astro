---
interface Props {
  skills?: { name: string; items: string[] }[];
}

const { skills } = Astro.props;
---

<section id="skills" class="py-20 px-4 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-cyan-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 -z-10"></div>
  <div class="absolute top-20 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-0 w-80 h-80 bg-accent/5 rounded-full blur-3xl"></div>

  <div class="max-w-5xl mx-auto relative">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        技能专长
      </h2>
      <div class="w-20 h-1.5 bg-gradient-to-r from-primary to-accent mx-auto rounded-full"></div>
    </div>

    {skills && skills.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {skills.map((category, index) => (
          <div class="group bg-white/80 dark:bg-gray-800/50 rounded-2xl p-6 shadow-md hover:shadow-xl hover:shadow-primary/10 transition-all duration-300 border border-gray-100/50 dark:border-gray-700/50 backdrop-blur-sm">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-gradient-to-br from-primary to-accent rounded-xl flex items-center justify-center">
                <span class="text-white font-bold text-lg">{index + 1}</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                {category.name}
              </h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {category.items.map((skill) => (
                <span class="px-3 py-1.5 bg-gradient-to-r from-primary/10 to-accent/10 text-gray-700 dark:text-gray-300 hover:from-primary/20 hover:to-accent/20 rounded-lg text-sm font-medium transition-all duration-200 hover:scale-105">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
