---
interface Props {
  skills?: { name: string; items: string[] }[];
}

const { skills } = Astro.props;
---

<section id="skills" class="py-20 px-4 relative overflow-hidden">
  <div class="absolute inset-0 bg-white dark:bg-dark -z-10"></div>
  <div class="absolute top-20 right-0 w-96 h-96 rounded-full blur-3xl" style="background: var(--primary, #3b82f6); opacity: 0.05;"></div>
  <div class="absolute bottom-20 left-0 w-80 h-80 rounded-full blur-3xl" style="background: var(--accent, #06b6d4); opacity: 0.05;"></div>

  <div class="max-w-5xl mx-auto relative">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        技能专长
      </h2>
      <div class="w-20 h-1.5 mx-auto rounded-full" style="background: linear-gradient(to right, var(--primary, #3b82f6), var(--accent, #06b6d4));"></div>
    </div>

    {skills && skills.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {skills.map((category, index) => (
          <div class="bg-white/80 dark:bg-gray-800/50 rounded-2xl p-6 shadow-md border border-gray-100/50 dark:border-gray-700/50 backdrop-blur-sm">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, var(--primary, #3b82f6), var(--accent, #06b6d4));">
                <span class="text-white font-bold text-lg">{index + 1}</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                {category.name}
              </h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {category.items.map((skill) => (
                <span class="px-3 py-1.5 rounded-lg text-sm font-medium" style="background: linear-gradient(to right, color-mix(in srgb, var(--primary, #3b82f6) 10%, transparent), color-mix(in srgb, var(--accent, #06b6d4) 10%, transparent)); color: var(--primary-dark, #1e293b);">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
