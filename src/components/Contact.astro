---
interface Props {
  email?: string;
  socials?: { platform: string; url: string; icon: string }[];
}

const { email, socials } = Astro.props;
---

<section id="contact" class="py-24 px-4 bg-white dark:bg-dark relative overflow-hidden">
  <div class="absolute inset-0 opacity-60">
    <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full blur-3xl" style="background: var(--primary, #3b82f6); opacity: 0.15;"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 rounded-full blur-3xl" style="background: var(--accent, #06b6d4); opacity: 0.15;"></div>
  </div>

  <div class="max-w-3xl mx-auto text-center relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
      联系我
    </h2>
    <div class="w-20 h-1.5 mx-auto rounded-full mb-6" style="background: linear-gradient(to right, var(--primary, #3b82f6), var(--accent, #06b6d4));"></div>

    <p class="text-lg text-gray-600 dark:text-gray-300 mb-10">
      如果你有任何问题或合作意向，欢迎随时联系我！
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      {email && (
        <a
          href={`mailto:${email}`}
          class="px-8 py-4 text-white rounded-xl shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200 flex items-center gap-2 font-medium"
          style="background: linear-gradient(to right, var(--primary, #3b82f6), var(--accent, #06b6d4)); box-shadow: 0 10px 15px -3px color-mix(in srgb, var(--primary, #3b82f6) 30%, transparent);"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          {email}
        </a>
      )}

      {socials?.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-4 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 rounded-xl shadow-md hover:shadow-lg transition-all duration-200 flex items-center gap-2 font-medium border border-gray-200/50 dark:border-gray-700/50"
        >
          {social.platform}
        </a>
      ))}
    </div>
  </div>
</section>
