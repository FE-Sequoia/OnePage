---
interface Props {
  email?: string;
  socials?: { platform: string; url: string; icon: string }[];
}

const { email, socials } = Astro.props;
---

<section id="contact" class="py-24 px-4 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full blur-3xl opacity-30" style="background: linear-gradient(var(--primary), var(--accent));"></div>
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgba(59, 130, 246, 0.08) 1px, transparent 0); background-size: 30px 30px;"></div>
  </div>

  <div class="max-w-3xl mx-auto text-center relative z-10">
    <span class="inline-block px-4 py-1.5 rounded-full text-sm font-medium mb-4 glass-card" style="color: var(--primary);">Contact</span>
    <h2 class="text-4xl md:text-5xl font-bold mb-4 font-display">
      联系<span class="gradient-text">我</span>
    </h2>
    <p class="text-lg text-gray-600 dark:text-gray-300 mb-10 max-w-xl mx-auto">
      如果你有任何问题或合作意向，欢迎随时联系我！
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap justify-center gap-4 mb-12">
      {email && (
        <a
          href={`mailto:${email}`}
          class="group relative px-8 py-4 rounded-2xl overflow-hidden hover-lift hover-glow transition-all duration-500"
          style="background: linear-gradient(135deg, var(--primary), var(--accent));"
        >
          <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
          <span class="relative z-10 text-white font-semibold flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            {email}
          </span>
        </a>
      )}

      {socials?.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative px-6 py-4 rounded-2xl overflow-hidden hover-lift transition-all duration-300"
        >
          <div class="absolute inset-0 border-2 rounded-2xl" style="border-color: var(--primary);"></div>
          <div class="absolute inset-0 rounded-2xl bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <span class="relative z-10 text-gray-700 dark:text-gray-200 font-medium group-hover:gradient-text transition-all duration-300">
            {social.platform}
          </span>
        </a>
      ))}
    </div>

    <!-- Decorative -->
    <div class="flex justify-center gap-2 opacity-50">
      <div class="w-2 h-2 rounded-full" style="background: var(--primary);"></div>
      <div class="w-2 h-2 rounded-full" style="background: var(--accent);"></div>
      <div class="w-2 h-2 rounded-full" style="background: var(--primary);"></div>
    </div>
  </div>
</section>