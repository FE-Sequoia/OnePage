---
interface Props {
  email?: string;
  socials?: { platform: string; url: string; icon: string }[];
}

const { email, socials } = Astro.props;
---

<section id="contact" class="py-24 px-4" style="background: linear-gradient(180deg, #f8fafc 0%, #e0f2fe 100%);">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">联系我</h2>
    <div class="w-16 h-1 mx-auto rounded-full mb-6" style="background: linear-gradient(to right, var(--primary), var(--accent));"></div>
    <p class="text-gray-600 dark:text-gray-300 mb-8">
      如果你有任何问题或合作意向，欢迎随时联系我！
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      {email && (
        <a
          href={`mailto:${email}`}
          class="px-8 py-4 text-white rounded-xl font-semibold shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
          style="background: linear-gradient(135deg, var(--primary), var(--accent));"
        >
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            发送邮件
          </span>
        </a>
      )}

      {socials?.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-4 bg-white text-gray-700 rounded-xl font-semibold shadow-md hover:shadow-lg hover:-translate-y-1 transition-all duration-300 border-2 border-transparent hover:border-primary"
        >
          {social.platform}
        </a>
      ))}
    </div>
  </div>
</section>